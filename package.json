{
  "name": "vercel-ship-2026-workers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "workers:build": "npm run check:workers:types && node scripts/build-workers.mts",
    "workers:create": "node scripts/create-worker.mts",
    "test:workers": "node --test workers/*/*.test.ts",
    "check:format": "oxfmt --check",
    "check:types": "tsc --noEmit",
    "check:workers:types": "tsc -p tsconfig.workers.json --noEmit"
  },
  "dependencies": {
    "@vercel/blob": "^2.4.1",
    "@vercel/sandbox": "^2.2.0-beta.0",
    "ai": "^6.0.208",
    "debug": "^4.4.3",
    "protobufjs": "8.6.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/debug": "^4.1.13",
    "@types/node": "^20",
    "esbuild": "0.28.1",
    "oxfmt": "^0.55.0",
    "typescript": "^5",
    "vercel": "^54.18.3"
  },
  "engines": {
    "node": "26.x",
    "npm": "11.x"
  }
}
