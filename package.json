{
  "name": "vercel-ship-2026-workers",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "workers:build": "npm run check:workers:types && node scripts/build-workers.mts",
    "workers:create": "node scripts/create-worker.mts",
    "workers:deploy": "node scripts/deploy-workers.mts",
    "start": "next start",
    "test:workers": "node --test workers/*/*.test.ts",
    "check:lint": "eslint",
    "check:format": "oxfmt --check",
    "check:types": "tsc --noEmit",
    "check:workers:types": "tsc -p tsconfig.workers.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.210",
    "@base-ui/react": "^1.5.0",
    "@libsql/client": "^0.17.4",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@vercel/blob": "^2.4.1",
    "@vercel/sandbox": "^2.2.0-beta.0",
    "@workflow/ai": "5.0.0-beta.11",
    "ai": "^6.0.208",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.21.0",
    "nanoid": "^5.1.14",
    "next": "16.2.9",
    "protobufjs": "8.6.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "shadcn": "^4.11.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.6",
    "workflow": "5.0.0-beta.19",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@swc/core": "1.15.3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "oxfmt": "^0.55.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vercel": "^54.18.3"
  },
  "engines": {
    "node": "26.x",
    "npm": "11.x"
  }
